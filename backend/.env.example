# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dev auth bypass — set to true only for local development
DEV_BYPASS_AUTH=false
DEV_BYPASS_USER_ID=      # UUID from public.users, required when DEV_BYPASS_AUTH=true

# Twilio — https://console.twilio.com (optional, voice features disabled if not set)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WEBHOOK_BASE_URL=https://yourdomain.com
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# OpenAI voice fallback / realtime. Optional if you only use OpenRouter.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Agent LLMs - OpenRouter is used for channel agents by default
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Automation Hub

# Server
PORT=3005

# Social OAuth callbacks. Use your public backend URL in production.
SOCIAL_OAUTH_REDIRECT_BASE_URL=http://localhost:3005
META_GRAPH_API_VERSION=v20.0
META_OAUTH_STATE_SECRET=
META_OAUTH_SCOPES=public_profile

# Instagram — https://developers.facebook.com/apps
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_OAUTH_SCOPES=public_profile,instagram_basic,pages_show_list

# LinkedIn - https://learn.microsoft.com/linkedin/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# YouTube - https://developers.google.com/youtube/v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# Telegram - https://core.telegram.org/bots/api
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Facebook — https://developers.facebook.com/apps
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_OAUTH_SCOPES=public_profile,pages_show_list,pages_read_engagement

# Messenger — shares Facebook app credentials
MESSENGER_ACCESS_TOKEN=
MESSENGER_PAGE_ID=
MESSENGER_OAUTH_SCOPES=public_profile,pages_show_list,pages_messaging

# WhatsApp Business — https://developers.facebook.com/apps
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_OAUTH_SCOPES=public_profile,whatsapp_business_management,whatsapp_business_messaging

# X (Twitter) — https://developer.x.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# TikTok — https://developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Email (SMTP) — or use a provider like Resend/SendGrid
EMAIL_FROM=noreply@yourdomain.com
EMAIL_SMTP_HOST=smtp.yourdomain.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
